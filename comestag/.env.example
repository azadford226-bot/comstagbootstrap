# .env.example - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/comestag
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 64
AUTH_TOKEN_USER_SECRET_KEY=your_base64_encoded_jwt_secret_key_at_least_256_bits

# Token expiration in seconds
AUTH_TOKEN_ACCESS_DURATION=1800        # 30 minutes
AUTH_TOKEN_REFRESH_DURATION=18000      # 5 hours

# ============================================
# VERIFICATION CODE SECRET
# ============================================
# Generate with: openssl rand -base64 32
VERIFICATION_CODE_SECRET=your_verification_code_secret_here

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Option 1: SMTP (Gmail, etc.)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Option 2: SendGrid (preferred for production)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Common email settings
MAIL_FROM=noreply@yourcompany.com
MAIL_FROM_NAME=Your Company Name

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true

# Login endpoint
RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_REFILL_TOKENS=5
RATE_LIMIT_LOGIN_REFILL_DURATION=15

# Registration endpoint
RATE_LIMIT_REGISTER_CAPACITY=3
RATE_LIMIT_REGISTER_REFILL_TOKENS=3
RATE_LIMIT_REGISTER_REFILL_DURATION=60

# General API
RATE_LIMIT_API_CAPACITY=100
RATE_LIMIT_API_REFILL_TOKENS=100
RATE_LIMIT_API_REFILL_DURATION=1

# ============================================
# APPLICATION SETTINGS
# ============================================
SPRING_PROFILES_ACTIVE=dev
APP_BASE_URL=http://localhost:8080
